// This is your Prisma schema file for CloraAI

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["metrics"]
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

// ─── Subscription Plan Enums ────────────────────────────────────────────────
enum Plan {
  FREE
  PRO
  PREMIUM
  LIFETIME
}

enum SubscriptionStatus {
  ACTIVE
  EXPIRED
  CANCELLED
  PAST_DUE
  HALTED
  PAUSED
  PENDING
}

enum BillingCycle {
  MONTHLY
  YEARLY
}

enum PlanSource {
  RAZORPAY
  GOOGLE_PLAY
  ADMIN
  REFERRAL
}

// ─── Users Table ─────────────────────────────────────────────────────────────
model User {
  id           String  @id @default(auto()) @map("_id") @db.ObjectId
  email        String  @unique
  password     String
  username     String?
  phoneNumber  String?
  profileImage String?
  pushToken    String? // Expo push token
  role         String  @default("USER") // USER | ADMIN | SUSPENDED | BANNED
  bio          String?
  tokenVersion Int     @default(0) // Enforces forced-logout (Phase 1)

  // ── Account Security & Compliance ───────────────────────────────────────
  tosAccepted            Boolean   @default(false)
  tosAcceptedAt          DateTime?
  isEmailVerified        Boolean   @default(false)
  emailVerificationToken String?
  twoFactorSecret        String?
  twoFactorEnabled       Boolean   @default(false)
  failedLoginAttempts    Int       @default(0)
  lockoutUntil           DateTime?
  resetPasswordToken     String?
  resetPasswordExpires   DateTime?

  // ── Subscription Plan (single-source-of-truth) ──────────────────────────
  plan               Plan                @default(FREE)
  subscriptionStatus SubscriptionStatus? // null = never subscribed
  planSource         PlanSource?
  planStartDate      DateTime?
  planEndDate        DateTime? // null = LIFETIME / never expires
  manuallyUpgraded   Boolean             @default(false) // Admin override flag
  paymentStatus      String              @default("NONE") // NONE | SUCCESS | FAILED
  retryAttempts      Int                 @default(0)
  credits            Int                 @default(0)
  pausedAt           DateTime?           // For manual pause/resume logic
  trialEndDate       DateTime?           // For free trial grants

  // ── Razorpay Live Link ───────────────────────────────────────────────────
  razorpayCustomerId           String?
  razorpaySubscriptionId       String?
  billingCycle                 BillingCycle?
  currentPeriodEnd             DateTime?
  activeRazorpaySubscriptionId String? // Legacy field — keep for compat

  // ── Referral & Growth Engine ───────────────────────────────────────────
  referralCode String?

  referredById String? @db.ObjectId
  referredBy   User?   @relation("ReferralHistory", fields: [referredById], references: [id], onDelete: NoAction, onUpdate: NoAction)
  referrals    User[]  @relation("ReferralHistory")

  // Analytics & Rewards Tracking
  totalReferrals        Int @default(0)
  paidReferrals         Int @default(0)
  milestoneClaimedCount Int @default(0)

  // Fraud Detection Surface
  fraudScore        Int     @default(0)
  isFlagged         Boolean @default(false)
  ipAddress         String?
  deviceFingerprint String?

  referralTransactionsGiven ReferralTransaction[] @relation("GivenRewards")
  referralTransactionsGot   ReferralTransaction[] @relation("ReceivedRewards")

  // ── YouTube Integration ───────────────────────────────────────────────
  youtubeConnected    Boolean @default(false)
  youtubeChannelId    String?
  youtubeAccessToken  String?
  youtubeRefreshToken String?
  youtubeSubscriberCount Int?     @default(0)
  youtubeViewCount       Int?     @default(0)
  youtubeVideoCount      Int?     @default(0)
  youtubeLastSyncedAt    DateTime?

  // ── Relations ───────────────────────────────────────────────────────────
  instagramAccounts     InstagramAccount[]
  paymentHistory        PaymentHistory[]
  dmAutomations         DMAutomation[]
  dmInteractions        DmInteraction[]
  analyticsSnapshot     AnalyticsSnapshot[]
  youtubeSnapshots      YoutubeAnalyticsSnapshot[]
  notifications         Notification[]
  aiUsage               AIUsage[]
  brandDealInteractions BrandDealInteraction[]
  brandDealReplies      BrandDealReply[]
  youtubeComments       YoutubeComment[]
  youtubeRules          YoutubeAutomationRule[]
  youtubeLeads          YoutubeLead[]
  deviceTokens          DeviceToken[]

  // ── Session & Activity Tracking ─────────────────────────────────────────
  loginSessions         LoginSession[]
  failedLogoutAttempts  Int       @default(0)
  logoutLockoutUntil    DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([plan])
  @@index([createdAt])
  @@index([planEndDate])
}

// User Sessions
// Instagram-style Login Sessions
model LoginSession {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  userId       String   @db.ObjectId
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  deviceName   String?  // e.g., "iPhone 13", "Samsung Galaxy"
  deviceType   String?  // mobile, tablet, desktop
  os           String?  // e.g., "iOS", "Windows"
  browser      String?  // e.g., "Chrome", "Safari"
  ipAddress    String?
  city         String?
  region       String?
  country      String?
  timezone     String?
  sessionToken String?  @unique
  isCurrent    Boolean  @default(false)
  loginTime    DateTime @default(now())
  lastActive   DateTime @default(now())
  expiresAt    DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([userId])
}


// In-App Notifications
model Notification {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  userId    String   @db.ObjectId
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      String   @default("system") // system | brand_deal | milestone | schedule | referral
  icon      String   @default("notifications")
  color     String   @default("#6D28D9")
  title     String
  body      String
  metadata  String?  // JSON string for deep linking: { screen: '...', params: {} }
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([userId, createdAt(sort: Desc)])
}

// Instagram Account Integration
model InstagramAccount {
  id     String @id @default(auto()) @map("_id") @db.ObjectId
  userId String @unique @db.ObjectId
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  instagramId        String    @unique
  username           String?
  pageId             String?
  pageAccessToken    String?
  instagramAccessToken String
  accountType        String?
  mediaCount         Int       @default(0)
  tokenExpiresAt     DateTime

  isConnected  Boolean   @default(true)
  connectedAt  DateTime  @default(now())
  lastSyncedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("instagramaccounts")
}

// ─── Payment History (Razorpay Audit Trail) ───────────────────────────────────
model PaymentHistory {
  id     String @id @default(auto()) @map("_id") @db.ObjectId
  userId String @db.ObjectId
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  razorpaySubscriptionId String? // Razorpay sub_xxx id
  razorpayPaymentId      String? // Razorpay pay_xxx id
  razorpayOrderId        String? // Razorpay order_xxx id
  transactionId          String? // Generic transaction/token ID for others (e.g. G-Play)

  amount   Int // amount in paise (₹199 = 19900)
  currency String @default("INR")
  status   String @default("PENDING") // PENDING | SUCCESS | FAILED | REFUNDED

  planName      String    @default("PRO") // snapshot of plan they paid for
  startDate     DateTime?
  endDate       DateTime?
  paymentMethod String? // upi | card | netbanking | wallet
  processed     Boolean   @default(false) // Webhook idempotency link
  refundedAmount Int      @default(0) // Track partial refunds

  createdAt DateTime @default(now())

  @@index([userId])
  @@index([razorpaySubscriptionId])
  @@index([status])
  @@index([createdAt])

  invoice       Invoice?
}

// ─── SaaS Invoices (PDF/Snapshots) ──────────────────────────────────────────
model Invoice {
  id               String   @id @default(auto()) @map("_id") @db.ObjectId
  userId           String   @db.ObjectId
  paymentHistoryId String   @db.ObjectId @unique
  invoiceNumber    String   @unique // INV-2026-0001
  amount           Int      // in paise
  currency         String   @default("INR")
  billingDate      DateTime @default(now())
  pdfUrl           String?
  customerName     String?
  customerEmail    String?
  status           String   @default("PAID") // PAID | OPEN | VOID

  paymentHistory   PaymentHistory @relation(fields: [paymentHistoryId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

// ─── Razorpay Webhook Event Deduplication ────────────────────────────────────
// Stores processed Razorpay event IDs to guarantee exactly-once processing.
// On duplicate delivery, @unique on eventId causes early return (idempotent).
model WebhookEvent {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  eventId     String   @unique // Razorpay event.id (e.g. "evt_XXXXX")
  eventType   String // e.g. "subscription.charged"
  processedAt DateTime @default(now())

  @@index([eventType])
  @@index([processedAt])
}



// Analytics Snapshots
model AnalyticsSnapshot {
  id     String @id @default(auto()) @map("_id") @db.ObjectId
  userId String @db.ObjectId
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  followers         Int?
  following         Int?
  mediaCount        Int?
  engagementRate    Float?   @default(0)
  impressions       Int?     @default(0)
  reach             Int?     @default(0)
  unfollowed        Int?     @default(0)
  topPostId         String?
  topPostEngagement Float?   @default(0)

  snapshotDate DateTime? @default(now())
  createdAt    DateTime? @default(now())

  @@index([userId, snapshotDate(sort: Desc)])
  @@map("instagramanalytics")
}

// DM Automation Rules
model DMAutomation {
  id     String @id @default(auto()) @map("_id") @db.ObjectId
  userId String @db.ObjectId
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  keyword          String?
  autoReplyMessage String?
  isActive         Boolean @default(true)

  reelId           String? // Specific reel ID. If null, applies globally.
  
  // Advanced Features
  isAI             Boolean @default(false)
  triggerType      String  @default("keywords") // 'keywords' | 'any'
  replyType        String  @default("text")     // 'text' | 'product'
  
  publicReplies    String? // JSON string store of array
  
  productName      String?
  productUrl       String?
  productDescription String?
  
  mustFollow       Boolean @default(false)

  // Custom Follow Request (Image 1)
  customFollowEnabled Boolean @default(false)
  customFollowHeader  String?
  customFollowSubtext String?
  followButtonText    String?
  followedButtonText  String?
  dmButtonText        String?
  dmReplyEnabled      Boolean @default(false)

  appendLinks      Boolean @default(false)
  link1            String?
  link2            String?
  link3            String?
  link4            String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, keyword, reelId])
  @@index([userId])
}

// DM Automation Interaction Log (Idempotency + Daily Limit)
model DmInteraction {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  userId    String   @db.ObjectId
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  messageId String   @unique // Meta message mid — ensures idempotency
  ruleId    String? // Which rule triggered this reply
  status    String   @default("sent") // sent | skipped | failed
  createdAt DateTime @default(now())

  @@index([userId, createdAt(sort: Desc)])
}

// Brand Deal Detection
model BrandDeal {
  id String @id @default(auto()) @map("_id") @db.ObjectId

  dmContent      String
  senderUsername String

  confidence   Float   @default(0) // 0-1
  isBrandDeal  Boolean @default(false)
  dealCategory String? // fitness, fashion, tech, etc.

  flaggedAt DateTime @default(now())
  createdAt DateTime @default(now())

  interactions BrandDealInteraction[]
  replies      BrandDealReply[]

  @@index([createdAt])
  @@index([isBrandDeal])
}

// Track when a user ignores a brand deal
model BrandDealInteraction {
  id          String    @id @default(auto()) @map("_id") @db.ObjectId
  userId      String    @db.ObjectId
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  brandDealId String    @db.ObjectId
  brandDeal   BrandDeal @relation(fields: [brandDealId], references: [id], onDelete: Cascade)
  action      String    @default("ignored") // "ignored"
  createdAt   DateTime  @default(now())

  @@unique([userId, brandDealId, action])
  @@index([userId])
  @@index([brandDealId])
}

// Track when a user replies to a brand deal with a pitch
model BrandDealReply {
  id            String    @id @default(auto()) @map("_id") @db.ObjectId
  userId        String    @db.ObjectId
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  brandDealId   String    @db.ObjectId
  brandDeal     BrandDeal @relation(fields: [brandDealId], references: [id], onDelete: Cascade)
  pitch         String
  isShortlisted Boolean   @default(false)
  createdAt     DateTime  @default(now())

  @@unique([userId, brandDealId])
  @@index([userId])
  @@index([brandDealId])
}

// Password Reset Tokens
model PasswordReset {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  userId    String   @db.ObjectId
  token     String   @unique
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([userId])
}


// ── Enterprise Referral Ledger ─────────────────────────────────────────────
model ReferralTransaction {
  id              String   @id @default(auto()) @map("_id") @db.ObjectId
  inviterId       String   @db.ObjectId
  referredUserId  String   @db.ObjectId
  rewardMonths    Int      @default(0)
  status          String   @default("PENDING") // PENDING, APPROVED, BLOCKED, REVERSED
  razorpayEventId String   @unique // Webhook idempotency link
  fraudReason     String?
  unlocksAt       DateTime // Enforces the 7-day maturation delay
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  inviter      User @relation("GivenRewards", fields: [inviterId], references: [id], onDelete: Cascade)
  referredUser User @relation("ReceivedRewards", fields: [referredUserId], references: [id], onDelete: Cascade)

  @@index([status, unlocksAt])
  @@index([inviterId])
}

// ─── AI Usage Tracking (Cost Protection) ─────────────────────────────────
// Tracks per-user AI token consumption for financial safety and observability.
// month column ("YYYY-MM") enables O(1) global monthly aggregation at 50k users.
model AIUsage {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  userId    String   @db.ObjectId
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  feature   String // "caption" | "brand_deal"
  tokens    Int // OpenAI usage.total_tokens from API response
  month     String // "YYYY-MM" pre-computed for fast monthly GROUP BY
  createdAt DateTime @default(now())

  @@index([userId, feature, createdAt]) // fast per-user daily cap checks
  @@index([month, feature]) // fast global monthly aggregation
}

// ─── Admin Audit Log ─────────────────────────────────────────────────
// Permanent record of all admin plan overrides for compliance and debugging.
model AuditLog {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  adminId   String // Admin userId who performed the action
  targetId  String // userId of the affected user
  action    String // UPGRADE_PRO | DOWNGRADE_FREE | GRANT_LIFETIME | EXTEND | CANCEL | BLOCK_AI | UNBLOCK_AI
  details   String? // JSON: { before, after, reason }
  createdAt DateTime @default(now())

  @@index([targetId])
  @@index([adminId])
  @@index([createdAt])
}

// ─── YouTube Automation Models ──────────────────────────────────────────

model YoutubeComment {
  id     String @id @default(auto()) @map("_id") @db.ObjectId
  userId String @db.ObjectId
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  videoId     String
  channelId   String? // Link to specific YouTube channel
  commentId   String  @unique // YouTube comment ID (for deduplication)
  username    String // Author of the comment
  commentText String
  replied     Boolean @default(false)

  createdAt DateTime @default(now())

  @@index([userId, videoId, createdAt(sort: Desc)])
  @@index([replied, createdAt(sort: Desc)])
}

model YoutubeAutomationRule {
  id     String @id @default(auto()) @map("_id") @db.ObjectId
  userId String @db.ObjectId
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  keyword      String
  replyMessage String
  isActive     Boolean @default(true)
  replyDelay   Int     @default(0) // Delay in seconds before replying
  limitPerHour Int     @default(20) // Max replies per hour for this rule
  channelId    String? // Link to specific YouTube channel
  
  videoId      String? // Optional: If a rule is bound to a specific video
  isAI         Boolean @default(false)
  triggerType  String  @default("keywords") // 'keywords' | 'any'
  onlySubscribers Boolean @default(false)
  appendLinks  Boolean @default(false)
  link1        String?
  link2        String?
  link3        String?
  link4        String?

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // A user can use the same keyword for different videos. Null videoId means global.
  // Prisma unique constraint doesn't strictly work like "optional uniqueness" in MongoDB,
  // but we can define the compound index.
  @@unique([userId, keyword, videoId])
  @@index([userId])
}

model YoutubeLead {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  userId    String   @db.ObjectId
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name      String
  email     String
  phone     String?
  source    String   @default("youtube")
  channelId String?
  createdAt DateTime @default(now())

  @@index([userId])
}

model YoutubeAnalyticsSnapshot {
  id           String    @id @default(auto()) @map("_id") @db.ObjectId
  userId       String    @db.ObjectId
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  subscribers  Int?      @default(0)
  views        Int?      @default(0)
  videos       Int?      @default(0)
  snapshotDate DateTime? @default(now())
  createdAt    DateTime? @default(now())

  @@unique([userId, snapshotDate])
  @@index([userId, snapshotDate(sort: Desc)])
}

// Device Push Tokens
// Supports multi-device notifications (Tab + iPhone)
model DeviceToken {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  userId      String   @db.ObjectId
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  token       String   @unique // Expo push token
  deviceName  String?  // e.g., "Ashok's Tab"
  deviceType  String?  // mobile, tablet, desktop
  os          String?  // e.g., "iOS", "Android"
  lastUsed    DateTime @default(now())
  createdAt   DateTime @default(now())

  @@index([userId])
}

// ─── System Configuration (Singleton/Global Settings) ────────────────────────
model SystemConfig {
  id              String   @id @default(auto()) @map("_id") @db.ObjectId
  key             String   @unique
  value           String   // Stored as JSON string
  updatedBy       String?  // Admin ID who last changed it
  updatedAt       DateTime @updatedAt
  createdAt       DateTime @default(now())
}

