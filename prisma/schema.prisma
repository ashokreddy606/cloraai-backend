// This is your Prisma schema file for CloraAI

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["metrics"]
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

// ─── Subscription Plan Enums ────────────────────────────────────────────────
enum Plan {
  FREE
  PRO
  LIFETIME
}

enum SubscriptionStatus {
  ACTIVE
  EXPIRED
  CANCELLED
  PAST_DUE
}

enum PlanSource {
  RAZORPAY
  ADMIN
  REFERRAL
}

// ─── Users Table ─────────────────────────────────────────────────────────────
model User {
  id           String  @id @default(auto()) @map("_id") @db.ObjectId
  email        String  @unique
  password     String
  username     String?
  phoneNumber  String?
  profileImage String?
  pushToken    String? // Expo push token
  role         String  @default("USER") // USER | ADMIN | SUSPENDED | BANNED
  tokenVersion Int     @default(0) // Enforces forced-logout (Phase 1)

  // ── Account Security & Compliance ───────────────────────────────────────
  tosAccepted            Boolean   @default(false)
  tosAcceptedAt          DateTime?
  isEmailVerified        Boolean   @default(false)
  emailVerificationToken String?
  twoFactorSecret        String?
  twoFactorEnabled       Boolean   @default(false)
  failedLoginAttempts    Int       @default(0)
  lockoutUntil           DateTime?

  // ── Subscription Plan (single-source-of-truth) ──────────────────────────
  plan               Plan                @default(FREE)
  subscriptionStatus SubscriptionStatus? // null = never subscribed
  planSource         PlanSource?
  planStartDate      DateTime?
  planEndDate        DateTime? // null = LIFETIME / never expires
  manuallyUpgraded   Boolean             @default(false) // Admin override flag
  paymentStatus      String              @default("NONE") // NONE | SUCCESS | FAILED
  retryAttempts      Int                 @default(0)

  // ── Razorpay Live Link ───────────────────────────────────────────────────
  // Set in createOrder so webhook can find userId without depending on PaymentHistory.
  // Nulled on admin downgrade to block webhook from re-upgrading the user.
  activeRazorpaySubscriptionId String?

  // ── Referral & Growth Engine ───────────────────────────────────────────
  referralCode String?

  referredById String? @db.ObjectId
  referredBy   User?   @relation("ReferralHistory", fields: [referredById], references: [id], onDelete: NoAction, onUpdate: NoAction)
  referrals    User[]  @relation("ReferralHistory")

  // Analytics & Rewards Tracking
  totalReferrals        Int @default(0)
  paidReferrals         Int @default(0)
  milestoneClaimedCount Int @default(0)

  // Fraud Detection Surface
  fraudScore        Int     @default(0)
  isFlagged         Boolean @default(false)
  ipAddress         String?
  deviceFingerprint String?

  referralTransactionsGiven ReferralTransaction[] @relation("GivenRewards")
  referralTransactionsGot   ReferralTransaction[] @relation("ReceivedRewards")

  // ── YouTube Integration ───────────────────────────────────────────────
  youtubeChannelId    String?
  youtubeAccessToken  String?
  youtubeRefreshToken String?
  youtubeSubscriberCount Int?     @default(0)
  youtubeViewCount       Int?     @default(0)
  youtubeVideoCount      Int?     @default(0)
  youtubeLastSyncedAt    DateTime?

  // ── Relations ───────────────────────────────────────────────────────────
  instagramAccounts     InstagramAccount[]
  paymentHistory        PaymentHistory[]
  captions              Caption[]
  scheduledPosts        ScheduledPost[]
  dmAutomations         DMAutomation[]
  dmInteractions        DmInteraction[]
  analyticsSnapshot     AnalyticsSnapshot[]
  calendarTasks         CalendarTask[]
  notifications         Notification[]
  aiUsage               AIUsage[]
  brandDealInteractions BrandDealInteraction[]
  brandDealReplies      BrandDealReply[]
  youtubeComments       YoutubeComment[]
  youtubeRules          YoutubeAutomationRule[]
  youtubeLeads          YoutubeLead[]
  contentCalendars      ContentCalendar[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([plan])
  @@index([createdAt])
  @@index([planEndDate])
}

// Calendar Tasks
model CalendarTask {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  userId    String   @db.ObjectId
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String
  date      DateTime
  startTime String?
  endTime   String?
  platform  String   @default("general") // general, instagram, youtube
  repeat    String   @default("one-time") // one-time, daily, weekly
  notes     String?
  color     String   @default("#6D28D9")
  completed Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, date])
}

// In-App Notifications
model Notification {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  userId    String   @db.ObjectId
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      String   @default("system") // system | brand_deal | milestone | schedule | referral
  icon      String   @default("notifications")
  color     String   @default("#6D28D9")
  title     String
  body      String
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([userId, createdAt])
}

// Instagram Account Integration
model InstagramAccount {
  id     String @id @default(auto()) @map("_id") @db.ObjectId
  userId String @unique @db.ObjectId
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  instagramId        String    @unique
  username           String?
  pageId             String?
  pageAccessToken    String?
  instagramAccessToken String
  accountType        String?
  mediaCount         Int       @default(0)
  tokenExpiresAt     DateTime

  isConnected  Boolean   @default(true)
  connectedAt  DateTime  @default(now())
  lastSyncedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ─── Payment History (Razorpay Audit Trail) ───────────────────────────────────
model PaymentHistory {
  id     String @id @default(auto()) @map("_id") @db.ObjectId
  userId String @db.ObjectId
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  razorpaySubscriptionId String? // Razorpay sub_xxx id
  razorpayPaymentId      String? @unique // Razorpay pay_xxx id
  razorpayOrderId        String? // Razorpay order_xxx id

  amount   Int // amount in paise (₹199 = 19900)
  currency String @default("INR")
  status   String @default("PENDING") // PENDING | SUCCESS | FAILED | REFUNDED

  planName      String    @default("PRO") // snapshot of plan they paid for
  startDate     DateTime?
  endDate       DateTime?
  paymentMethod String? // upi | card | netbanking | wallet
  processed     Boolean   @default(false) // Webhook idempotency link
  refundedAmount Int      @default(0) // Track partial refunds

  createdAt DateTime @default(now())

  @@index([userId])
  @@index([razorpaySubscriptionId])
  @@index([status])
  @@index([createdAt])
}

// ─── Razorpay Webhook Event Deduplication ────────────────────────────────────
// Stores processed Razorpay event IDs to guarantee exactly-once processing.
// On duplicate delivery, @unique on eventId causes early return (idempotent).
model WebhookEvent {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  eventId     String   @unique // Razorpay event.id (e.g. "evt_XXXXX")
  eventType   String // e.g. "subscription.charged"
  processedAt DateTime @default(now())

  @@index([eventType])
  @@index([processedAt])
}

// AI Generated Captions
model Caption {
  id     String @id @default(auto()) @map("_id") @db.ObjectId
  userId String @db.ObjectId
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  topic    String
  tone     String // professional, casual, funny, motivational
  length   String // short, medium, long
  content  String
  hashtags String // comma-separated

  isUsed       Boolean   @default(false)
  usedInPostId String?
  usedAt       DateTime?

  // Compliance: AI Content Reporting
  isReported   Boolean   @default(false)
  reportReason String?
  reportedAt   DateTime?

  createdAt DateTime @default(now())

  @@index([userId])
  @@index([isUsed])
  @@index([createdAt])
}

// Scheduled Posts
model ScheduledPost {
  id     String @id @default(auto()) @map("_id") @db.ObjectId
  userId String @db.ObjectId
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  platform    String    @default("instagram")
  mediaUrl    String
  title       String?
  caption     String?
  scheduledAt DateTime
  status      String    @default("scheduled") // scheduled, published, failed
  publishedAt DateTime?
  videoType   String?   // reels, shorts, etc.
  calendarDay Int?
  retryCount  Int       @default(0) // tracks failed attempts

  instagramPostId String?
  errorMessage    String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([status])
  @@index([scheduledAt])
}

model ContentCalendar {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  userId    String   @db.ObjectId
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  startDate DateTime
  endDate   DateTime
  createdAt DateTime @default(now())

  @@index([userId])
}

// Analytics Snapshots
model AnalyticsSnapshot {
  id     String @id @default(auto()) @map("_id") @db.ObjectId
  userId String @db.ObjectId
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  followers         Int
  following         Int
  mediaCount        Int
  engagementRate    Float   @default(0)
  impressions       Int     @default(0)
  reach             Int     @default(0)
  topPostId         String?
  topPostEngagement Float   @default(0)

  snapshotDate DateTime @default(now())
  createdAt    DateTime @default(now())

  @@index([userId])
  @@index([snapshotDate])
  @@index([userId, snapshotDate])
}

// DM Automation Rules
model DMAutomation {
  id     String @id @default(auto()) @map("_id") @db.ObjectId
  userId String @db.ObjectId
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  keyword          String
  autoReplyMessage String
  isActive         Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, keyword])
  @@index([userId])
}

// DM Automation Interaction Log (Idempotency + Daily Limit)
model DmInteraction {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  userId    String   @db.ObjectId
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  messageId String   @unique // Meta message mid — ensures idempotency
  ruleId    String? // Which rule triggered this reply
  status    String   @default("sent") // sent | skipped | failed
  createdAt DateTime @default(now())

  @@index([userId, createdAt]) // Fast rolling 24hr window queries
}

// Brand Deal Detection
model BrandDeal {
  id String @id @default(auto()) @map("_id") @db.ObjectId

  dmContent      String
  senderUsername String

  confidence   Float   @default(0) // 0-1
  isBrandDeal  Boolean @default(false)
  dealCategory String? // fitness, fashion, tech, etc.

  flaggedAt DateTime @default(now())
  createdAt DateTime @default(now())

  interactions BrandDealInteraction[]
  replies      BrandDealReply[]

  @@index([createdAt])
  @@index([isBrandDeal])
}

// Track when a user ignores a brand deal
model BrandDealInteraction {
  id          String    @id @default(auto()) @map("_id") @db.ObjectId
  userId      String    @db.ObjectId
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  brandDealId String    @db.ObjectId
  brandDeal   BrandDeal @relation(fields: [brandDealId], references: [id], onDelete: Cascade)
  action      String    @default("ignored") // "ignored"
  createdAt   DateTime  @default(now())

  @@unique([userId, brandDealId, action])
  @@index([userId])
  @@index([brandDealId])
}

// Track when a user replies to a brand deal with a pitch
model BrandDealReply {
  id            String    @id @default(auto()) @map("_id") @db.ObjectId
  userId        String    @db.ObjectId
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  brandDealId   String    @db.ObjectId
  brandDeal     BrandDeal @relation(fields: [brandDealId], references: [id], onDelete: Cascade)
  pitch         String
  isShortlisted Boolean   @default(false)
  createdAt     DateTime  @default(now())

  @@unique([userId, brandDealId])
  @@index([userId])
  @@index([brandDealId])
}

// Password Reset Tokens
model PasswordReset {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  userId    String   @db.ObjectId
  token     String   @unique
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([userId])
}

// Cron Worker Leader Lock (Multi-Instance Safety)
model CronLock {
  id       String   @id @default(auto()) @map("_id") @db.ObjectId
  lockName String   @unique // e.g., 'scheduler', 'token-refresh'
  lockedAt DateTime // Timestamp when lock was acquired
  lockedBy String? // Optional: process identifier (e.g., hostname)
}

// ── Enterprise Referral Ledger ─────────────────────────────────────────────
model ReferralTransaction {
  id              String   @id @default(auto()) @map("_id") @db.ObjectId
  inviterId       String   @db.ObjectId
  referredUserId  String   @db.ObjectId
  rewardMonths    Int      @default(0)
  status          String   @default("PENDING") // PENDING, APPROVED, BLOCKED, REVERSED
  razorpayEventId String   @unique // Webhook idempotency link
  fraudReason     String?
  unlocksAt       DateTime // Enforces the 7-day maturation delay
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  inviter      User @relation("GivenRewards", fields: [inviterId], references: [id], onDelete: Cascade)
  referredUser User @relation("ReceivedRewards", fields: [referredUserId], references: [id], onDelete: Cascade)

  @@index([status, unlocksAt])
  @@index([inviterId])
}

// ─── AI Usage Tracking (Cost Protection) ─────────────────────────────────
// Tracks per-user AI token consumption for financial safety and observability.
// month column ("YYYY-MM") enables O(1) global monthly aggregation at 50k users.
model AIUsage {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  userId    String   @db.ObjectId
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  feature   String // "caption" | "brand_deal"
  tokens    Int // OpenAI usage.total_tokens from API response
  month     String // "YYYY-MM" pre-computed for fast monthly GROUP BY
  createdAt DateTime @default(now())

  @@index([userId, feature, createdAt]) // fast per-user daily cap checks
  @@index([month, feature]) // fast global monthly aggregation
}

// ─── Admin Audit Log ─────────────────────────────────────────────────
// Permanent record of all admin plan overrides for compliance and debugging.
model AuditLog {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  adminId   String // Admin userId who performed the action
  targetId  String // userId of the affected user
  action    String // UPGRADE_PRO | DOWNGRADE_FREE | GRANT_LIFETIME | EXTEND | CANCEL | BLOCK_AI | UNBLOCK_AI
  details   String? // JSON: { before, after, reason }
  createdAt DateTime @default(now())

  @@index([targetId])
  @@index([adminId])
  @@index([createdAt])
}

// ─── YouTube Automation Models ──────────────────────────────────────────

model YoutubeComment {
  id     String @id @default(auto()) @map("_id") @db.ObjectId
  userId String @db.ObjectId
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  videoId     String
  channelId   String? // Link to specific YouTube channel
  commentId   String  @unique // YouTube comment ID (for deduplication)
  username    String // Author of the comment
  commentText String
  replied     Boolean @default(false)

  createdAt DateTime @default(now())

  @@index([userId, videoId])
  @@index([replied])
}

model YoutubeAutomationRule {
  id     String @id @default(auto()) @map("_id") @db.ObjectId
  userId String @db.ObjectId
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  keyword      String
  replyMessage String
  isActive     Boolean @default(true)
  replyDelay   Int     @default(0) // Delay in seconds before replying
  limitPerHour Int     @default(20) // Max replies per hour for this rule
  channelId    String? // Link to specific YouTube channel
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([userId, keyword])
  @@index([userId])
}

model YoutubeLead {
  id     String @id @default(auto()) @map("_id") @db.ObjectId
  userId String @db.ObjectId
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  name   String
  email  String
  phone  String?
  source String  @default("youtube")
  channelId String? // Link to specific YouTube channel
  createdAt DateTime @default(now())

  @@index([userId])
}
