# ============================================================================
# CloraAI Backend — Environment Variables
# ============================================================================
# INSTRUCTIONS:
#   1. Copy this file to `.env`
#   2. Replace every CHANGE_ME value with your actual credentials
#   3. NEVER commit `.env` to Git
#   4. In production (Railway), set all variables via the dashboard — not .env
# ============================================================================

# ── Database ────────────────────────────────────────────────────────────────
# MongoDB Atlas connection string. Must include username, password, and DB name.
# Example: mongodb+srv://user:password@cluster.mongodb.net/cloraai?retryWrites=true&w=majority
DATABASE_URL="CHANGE_ME_mongodb_connection_string"

# ── JWT Authentication ──────────────────────────────────────────────────────
# MUST be at least 64 random bytes for production security.
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET="CHANGE_ME_generate_with_crypto_randomBytes_64"
JWT_EXPIRE="1h"

# Optional: Previous secret for zero-downtime key rotation
# JWT_SECRET_PREVIOUS=""

# ── Internal Monitoring ─────────────────────────────────────────────────────
# Token for /internal/metrics endpoint. Generate a random 32-byte hex string.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
INTERNAL_METRICS_TOKEN="CHANGE_ME_random_32_byte_hex"

# ── Meta (Facebook/Instagram) ──────────────────────────────────────────────
# Get from: https://developers.facebook.com → Your App → Settings → Basic
META_WEBHOOK_VERIFY_TOKEN="CHANGE_ME_random_webhook_verify_token"
PAGE_ACCESS_TOKEN="CHANGE_ME_get_from_meta_graph_api"
INSTAGRAM_APP_ID="CHANGE_ME_from_meta_developer_console"
INSTAGRAM_APP_SECRET="CHANGE_ME_from_meta_developer_console"
INSTAGRAM_REDIRECT_URI="https://your-domain.com/auth/instagram/callback"
META_GRAPH_API_VERSION="v22.0"

# ── Admin ───────────────────────────────────────────────────────────────────
# Secret key for admin promotion endpoint. Generate a random 32-byte hex string.
ADMIN_SECRET_KEY="CHANGE_ME_random_admin_secret"

# ── OpenAI ──────────────────────────────────────────────────────────────────
OPENAI_API_KEY="CHANGE_ME_sk_proj_from_openai_dashboard"

# ── Razorpay (if used) ──────────────────────────────────────────────────────
RAZORPAY_KEY_ID="CHANGE_ME"
RAZORPAY_KEY_SECRET="CHANGE_ME"
RAZORPAY_WEBHOOK_SECRET="CHANGE_ME"
RAZORPAY_PLAN_ID="CHANGE_ME"

# ── Server ──────────────────────────────────────────────────────────────────
# DO NOT set NODE_ENV here. Set it via your deployment platform (Railway, etc.)
# NODE_ENV is intentionally omitted — Railway sets it automatically.
PORT=8080
FRONTEND_URL="http://localhost:8081,http://localhost:5173"

# ── Email (Resend API — preferred) ──────────────────────────────────────────
RESEND_API_KEY="CHANGE_ME_re_from_resend_dashboard"
EMAIL_FROM="CloraAI <onboarding@resend.dev>"
BASE_URL="https://your-domain.com"

# ── Email (Nodemailer — fallback) ───────────────────────────────────────────
EMAIL_USER="CHANGE_ME_your_gmail"
EMAIL_PASS="CHANGE_ME_your_app_password"

# ── Google Play Developer API ───────────────────────────────────────────────
# Create a service account in GCP, download JSON key, paste as single-line JSON
GOOGLE_PLAY_SERVICE_ACCOUNT_JSON="CHANGE_ME_paste_service_account_json"

# ── Google OAuth ────────────────────────────────────────────────────────────
# Get from: Google Cloud Console → APIs & Credentials → OAuth 2.0 Client ID
GOOGLE_CLIENT_ID="CHANGE_ME_from_google_cloud_console"
GOOGLE_CLIENT_SECRET="CHANGE_ME_from_google_cloud_console"

# ── YouTube OAuth ───────────────────────────────────────────────────────────
YOUTUBE_CLIENT_ID="CHANGE_ME_from_google_cloud_console"
YOUTUBE_CLIENT_SECRET="CHANGE_ME_from_google_cloud_console"
YOUTUBE_REDIRECT_URI="https://your-domain.com/api/v1/youtube/callback"

# ── Token Encryption ───────────────────────────────────────────────────────
# AES-256 key for encrypting stored OAuth tokens. Generate 32-byte hex.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
TOKEN_ENCRYPTION_SECRET="CHANGE_ME_random_32_byte_hex_for_token_encryption"

# ── AWS S3 (Optional — for file uploads) ────────────────────────────────────
AWS_ACCESS_KEY_ID="CHANGE_ME"
AWS_SECRET_ACCESS_KEY="CHANGE_ME"
AWS_REGION="us-east-1"
AWS_S3_BUCKET_NAME="cloraai-assets"

# ── Redis (Required for production) ────────────────────────────────────────
# Required for rate limiting, session management, and BullMQ workers.
REDIS_URL="CHANGE_ME_redis_connection_url"

# ── Sentry (Optional — error tracking) ─────────────────────────────────────
# SENTRY_DSN=""

# ── AI Budget Controls ──────────────────────────────────────────────────────
# AI_MONTHLY_TOKEN_BUDGET=5000000
# AI_MAX_CONCURRENT=25
